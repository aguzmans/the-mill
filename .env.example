# Copy to `.env` and `docker compose up -d api worker redis` picks it up (no rebuild).
#
# Point Mill at your own GitHub repo (folder-per-project layout). Use an HTTPS URL
# and a Personal Access Token with repo read access. (Leave unset to use the demo
# repo baked into the image.)

# HTTPS clone URL — NOT the git@… SSH form:
#   git@github.com:acme/mill-config.git   →   https://github.com/acme/mill-config.git
PROJECT_REPO=https://github.com/acme/mill-config.git
PROJECT_BRANCH=main

# GitHub Personal Access Token (fine-grained: Contents = read; or classic: repo).
GIT_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Optional:
# RECONCILE_INTERVAL_MS=15000
