{
  "name": "the-mill",
  "private": true,
  "version": "0.0.1",
  "description": "Mill — a GitOps-native workflow-automation platform (Windmill/n8n replacement). Prototype iteration.",
  "license": "MIT",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspace apps/web run build",
    "preview": "npm --workspace apps/web run preview",
    "test:e2e": "npm --workspace apps/web run test:e2e",
    "test:unit": "bun test packages apps/cli apps/api",
    "typecheck:backend": "tsc -p tsconfig.backend.json",
    "mill": "bun apps/cli/src/mill.ts"
  },
  "dependencies": {
    "croner": "^8.1.2",
    "hono": "^4.6.14",
    "ioredis": "^5.4.2",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "bun-types": "^1.3.14"
  }
}
